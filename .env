#----------------- Application Core ---------
APP_NAME="CSMP"
APP_FULL_NAME="CTS Student Management Portal"
APP_URL="http://localhost:8000"
APP_REPO="https://github.com/soymadip/CSMP"

APP_LOCALE="en"
APP_TIMEZONE="Asia/Kolkata"
APP_KEY=

SUPERADMIN_EMAIL="sadmin@csmp.in"
SUPERADMIN_PASSWORD="SuperPasswd"

#----------------- Institutional Identity -----------------
INSTITUTE_NAME="The Calcutta Technical School"
INSTITUTE_SUBTITLE="Govt. of W.B"
INSTITUTE_ADDRESS="110, S.N. BANERJEE ROAD, KOLKATA-700 013"
INSTITUTE_PHONE="Not Available"
INSTITUTE_MAP_URL="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3684.461027015059!2d88.35479071171858!3d22.561854133277084!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3a02770731aeafcf%3A0x70b7fa2f49a82e14!2sThe%20Calcutta%20Technical%20School!5e0!3m2!1sen!2sin!4v1773561647084!5m2!1sen!2sin"

#-------------- Database Connection (laravel & docker) --------------
DB_CONNECTION="mysql"
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE="csmp"
DB_USERNAME="admin"
DB_PASSWORD="csmp_Admin"
DB_ROOT_PASSWORD="csmp_Root"

# PhpmyAdmin
PMA_URL="http://localhost:8080"
PMA_THEME="metro"

#----------------- Drivers & Queues ---------
SESSION_DRIVER="database"
SESSION_LIFETIME=120
QUEUE_CONNECTION="database"
CACHE_STORE="database"

#----------------- Vite Integration ---------
VITE_APP_NAME="${APP_NAME}"
